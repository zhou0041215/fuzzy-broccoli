# =========================
# App
# =========================
APP_NAME=FlowCV
APP_CN_NAME=FlowCV
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# =========================
# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FILE 留空时只输出到控制台；配置后会写入滚动日志文件
# =========================
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=WARNING
LOG_ACCESS_ENABLED=true
LOG_FILE=
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# MySQL Database
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=flowcv
DB_CHARSET=utf8mb4

# =========================
# Redis
# 生产环境请设置密码，例如：redis://:password@127.0.0.1:6379/0
# =========================
REDIS_URL=redis://127.0.0.1:6379/0
ANNOUNCEMENT_CACHE_TTL_SECONDS=600
REDIS_KEY_PREFIX=flowcv
REDIS_SOCKET_TIMEOUT=3

# =========================
# JWT
# =========================
JWT_SECRET_KEY=please_change_this_secret_key
ADMIN_EMAILS=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================
# SMTP Email
# 以 QQ 邮箱为例：SMTP_HOST=smtp.qq.com，SMTP_PORT=465，密码使用邮箱授权码
# =========================
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FlowCV
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_TIMEOUT=10
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_SEND_INTERVAL_SECONDS=60
EMAIL_CODE_REGISTER_LOCK_SECONDS=30

# =========================
# AI Model
# OpenAI compatible API
# =========================
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.7
AI_TIMEOUT=60
AI_MAX_TOKENS=8192

# =========================
# Storage
# STORAGE_PROVIDER: minio | aliyun_oss
# STORAGE_PUBLIC_URL_MODE: proxy | public
# proxy  = 上传后返回 /api/files/{object_name}，由后端代理读取，最稳妥
# public = 上传后返回对象存储公网地址，需要 bucket/CDN 可公开读取
# =========================
STORAGE_PROVIDER=minio
STORAGE_PUBLIC_URL_MODE=proxy

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flowcv
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://127.0.0.1:9000/flowcv

# Aliyun OSS
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PUBLIC_URL=
ALIYUN_OSS_SECURE=true

# =========================
# Export / Upload
# =========================
EXPORT_DIR=storage/exports
UPLOAD_DIR=storage/uploads
PDF_BASE_URL=http://127.0.0.1:8000
# chromium = 严格使用 Chromium；auto = Chromium 失败后回退 WeasyPrint；weasyprint = 仅使用 WeasyPrint
PDF_RENDERER=chromium
PDF_CHROMIUM_EXECUTABLE_PATH=
PDF_RENDER_TIMEOUT_MS=30000

# =========================
# Frontend
# =========================
FRONTEND_URL=http://localhost:5173
